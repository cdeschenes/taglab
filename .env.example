# ─── Media ────────────────────────────────────────────────────────────────────
# Absolute path to your music library on the HOST machine.
# Docker: this mounts your host path to /media inside the container.
# Local dev: set MEDIA_PATH directly to your library path instead.
HOST_MEDIA_PATH=/path/to/your/music

# Path inside the container where the SQLite index and thumbnail cache are stored.
# When media is mounted read-only, point this to a writable volume (default: /cache).
CACHE_PATH=/cache

# Multiple libraries (optional) — comma-separated list of  /path:Label  pairs.
# The first entry becomes the default library on startup.
# Leave empty to use HOST_MEDIA_PATH as a single unnamed library.
# Example: LIBRARIES=/media:Main Library,/media2:Classical
LIBRARIES=

# ─── Authentication ────────────────────────────────────────────────────────────
AUTH_USER=admin
AUTH_PASSWORD=changeme

# Secret used to sign session cookies. Set this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ─── File Organizer (optional) ────────────────────────────────────────────────
# Leave ORGANIZE_TARGET empty to disable the "Organize Files" feature entirely.
# When set, files are moved to:  ORGANIZE_TARGET / <pattern>
#
# Available tokens: {album_artist} {album_artist_first} {artist} {artistsort} {albumartistsort}
#                   {album} {title} {track} {disc} {year} {date} {originalyear}
#                   {genre} {label} {composer} {key}
# {track} is zero-padded to 2 digits automatically.
#
# Example result:  /media/Pink Floyd/The Wall/01 - In the Flesh.flac
ORGANIZE_TARGET=/organized
ORGANIZE_PATTERN={album_artist_first}/{year} - {album}/{track:02d} - {title}.flac

# ─── File Organizer cleanup (optional) ───────────────────────────────────────
# Comma-separated glob patterns deleted from source dirs after a move.
# Prevents junk files from blocking empty-directory removal.
# Set to empty string to disable cleanup entirely.
ORGANIZE_CLEANUP_PATTERNS=._*,*.bak,.DS_Store,Thumbs.db

# ─── Navidrome (optional) ─────────────────────────────────────────────────────
# Leave NAVIDROME_URL empty to disable the "Trigger Rescan" feature.
# Use the internal Docker hostname if TagLab and Navidrome share a network.
NAVIDROME_URL=
NAVIDROME_USER=
NAVIDROME_PASSWORD=

# ─── Last.fm (optional) ───────────────────────────────────────────────────────
# Enables the artist info card (image, stats, bio, tags, similar artists).
# Get a free key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ─── Danger Zone (optional) ───────────────────────────────────────────────────
# Set to true to enable the "Move to Trash" feature.
# Albums and tracks are moved to a .trash folder inside MEDIA_PATH rather than
# permanently deleted. Use "Empty Trash" in the settings panel to purge.
ALLOW_DELETE=false
